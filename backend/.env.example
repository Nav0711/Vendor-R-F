# ─── Database (MySQL) ────────────────────────────────────────────────────────
# VendorLens uses MySQL. Set the connection details below (or provide a full
# DATABASE_URL to override them).
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/vendorlens?charset=utf8mb4
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=vendorlens
LOG_LEVEL=INFO

# ─── Required APIs ───────────────────────────────────────────────────────────
# Gemini LLM — findings extraction. Accepts EITHER key type; the backend
# auto-detects which endpoint to use from the key prefix:
#   AIza…   Google AI Studio       (aistudio.google.com)
#   AQ.Ab…  Vertex AI express mode (Google Cloud — no project/ADC needed)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash          # Optional — override the default model
# GEMINI_API_BACKEND=auto                # auto | studio | vertex — force the transport

# ─── Gemini cost controls ────────────────────────────────────────────────────
# Each scan = one Gemini request. The token cost is dominated by the news index and
# the per-alternate-name enrichment graph; lower the two knobs below for cheaper scans.
GEMINI_DAILY_CALL_CAP=25          # max Gemini requests/day
GEMINI_DAILY_TOKEN_CAP=200000     # max Gemini tokens/day — reserved up-front per scan
GEMINI_MAX_NEWS_ARTICLES=25       # articles sent for AI scoring (drives input AND output size)
GEMINI_MAX_PROMPT_TOKENS=15000    # per-scan ceiling; above it, enrichment is dropped
OPENSANCTIONS_API_KEY=your_key_here  # Sanctions / PEP screening
SERPER_API_KEY=your_key_here         # Google search (adverse, reviews, profile, news)
NEWS_API_KEY=your_key_here           # NewsAPI — adverse media + regulatory angle

# ─── Optional APIs ───────────────────────────────────────────────────────────
OPENCORPORATES_API_KEY=              # Company registry lookup (leave blank to skip)
GOOGLE_MAPS_API_KEY=                 # Google Places — address/business verification
MICROLINK_API_KEY=                   # Microlink website metadata (free tier works without a key)

# Wikipedia API — FREE, no key needed, always active.
# Wikimedia 403s any User-Agent without a contact handle, so set a REAL address here
# before going live — the default below is a placeholder and will be rejected.
# HTTP_USER_AGENT=VendorLens/1.0 (KYB due diligence; contact: you@yourcompany.com)

# GDELT — FREE, no key needed, always active

# ─── India-only APIs (required only for vendors with jurisdiction_country=IN) ─
# Omit or leave blank if you are not onboarding Indian vendors.
# AuthBridge: identity verification (GSTIN/PAN/MSMED), email verification,
#             court check, defaulting director check, global sanctions.
#
# NOT FUNCTIONAL until all three are set to real values. AUTHBRIDGE_BASE_URL has NO
# default — the old default host (api.authbridge.ai) does not exist in DNS. Get the
# real base URL and endpoint paths from AuthBridge's docs; the paths in endpoints.py
# are still unverified (see the `# CONFIRM with AuthBridge docs` comments).
# Left as placeholders, AuthBridge is cleanly skipped and the report shows
# "Not Verified" rather than failing.
AUTHBRIDGE_API_KEY=your_authbridge_api_key
AUTHBRIDGE_API_SECRET=your_authbridge_api_secret
# AUTHBRIDGE_BASE_URL=

# ─── Testing ─────────────────────────────────────────────────────────────────
MOCK_API_CALLS=false   # Set to true to skip all external API calls during development
TEST_MODE=false
